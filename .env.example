# ======================
# SPRING PROFILE
# ======================
SPRING_PROFILE=dev

# ======================
# DATABASE CONFIG (PostgreSQL local / Supabase)
# ======================
# Para desarrollo local con PostgreSQL
DB_URL=jdbc:postgresql://localhost:PUERTO/DB_NAME
DB_USER=DB_USER
DB_PASSWORD=DB_PASSWORD

# Para producción con Supabase (descomentar y configurar)
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?currentSchema=resource_service
# DB_USER=postgres.<project-ref>
# DB_PASSWORD=your-supabase-password

# ======================
# JWT CONFIG
# ======================
JWT_SECRET=JWT_SECRET
JWT_EXPIRATION=JWT_EXPIRATION

# ======================
# EXTERNAL SERVICES URLs
# ======================
# Desarrollo local
SERVICES_AUTH_URL=http://localhost:PUERTO
SERVICES_CATALOG_URL=http://localhost:PUERTO

# Producción en Render (descomentar cuando se despliegue)
# SERVICES_AUTH_URL=https://ms-auth-service.onrender.com
# SERVICES_CATALOG_URL=https://ms-catalog-service.onrender.com

# ======================
# SERVER CONFIG
# ======================
# Render asigna el puerto dinámicamente vía variable $PORT
# No definir PORT aquí para desarrollo local; se usa server.port en properties